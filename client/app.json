{
  "expo": {
    "name": "Pixel Library",
    "slug": "pixel-library",
    "description": "Track study sessions, manage breaks, and study with private groups.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pixellibrary",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.xikodev.pixellibrary",
      "supportsTablet": true
    },
    "android": {
      "package": "com.xikodev.pixellibrary",
      "permissions": [
        "INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "owner": "pixel-library",
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/with-play-store-hardening",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "projectName": "Pixel Library",
      "publicUrls": {
        "privacyPolicy": "https://appsupport.xikodev.xyz/pixel-library/privacy-policy/",
        "support": "https://appsupport.xikodev.xyz/pixel-library/support/",
        "accountDeletion": "https://appsupport.xikodev.xyz/pixel-library/account-deletion/",
        "supportEmail": "support@xikodev.xyz"
      }
    }
  }
}
